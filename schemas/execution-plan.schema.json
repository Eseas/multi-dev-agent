{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionPlan",
  "description": "Execution plan generated by skill-pm. The sole input source for the Orchestrator.",
  "type": "object",
  "required": ["task_id", "created_at", "requirements_ref", "pipeline", "stages", "summary"],
  "properties": {

    "task_id": {
      "type": "string",
      "description": "Unique task identifier (same as requirements.json)",
      "pattern": "^task-[0-9]+$"
    },

    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "format": "date-time"
    },

    "requirements_ref": {
      "type": "string",
      "description": "Path to the requirements.json used as input"
    },

    "pipeline": {
      "type": "object",
      "description": "Global pipeline configuration",
      "required": ["mode", "num_approaches", "complexity"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["alternative", "concern"],
          "description": "alternative: independent alternatives compared / concern: split by concern then integrated"
        },
        "num_approaches": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "Number of implementations (N). 1~3 based on complexity"
        },
        "complexity": {
          "type": "string",
          "enum": ["simple", "medium", "complex"],
          "description": "Overall complexity as assessed by the PM"
        }
      }
    },

    "stages": {
      "type": "object",
      "description": "Per-stage execution configuration",
      "required": ["architect", "implementer", "reviewer", "tester"],
      "properties": {

        "architect": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "If false, skip this stage. Can be skipped for simple complexity"
            },
            "focus": {
              "type": "string",
              "description": "Design focus hint to pass to the Architect"
            }
          }
        },

        "implementer": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "guidelines": {
              "type": "array",
              "description": "Guidelines to pass to the Implementer",
              "items": { "type": "string" }
            }
          }
        },

        "reviewer": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether code review is enabled"
            },
            "focus_areas": {
              "type": "array",
              "description": "Areas to focus on during review",
              "items": { "type": "string" }
            }
          }
        },

        "tester": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether testing is enabled"
            },
            "test_strategy": {
              "type": "string",
              "enum": ["unit", "integration", "e2e", "mixed"],
              "description": "Testing strategy"
            }
          }
        },

        "comparator": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enabled only when N >= 2 and mode is alternative"
            },
            "criteria": {
              "type": "array",
              "description": "Comparison criteria (ordered by weight)",
              "items": { "type": "string" }
            }
          }
        },

        "integrator": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enabled only when mode is concern"
            }
          }
        },

        "simplifier": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether the code cleanup/simplification stage is enabled"
            }
          }
        }
      }
    },

    "concerns": {
      "type": "array",
      "description": "Only for concern mode. Defines each concern",
      "items": {
        "type": "object",
        "required": ["name", "scope"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Concern name. e.g. frontend, backend, infra"
          },
          "scope": {
            "type": "string",
            "description": "Description of what this concern covers"
          }
        }
      }
    },

    "risk_notes": {
      "type": "array",
      "description": "Risks and caveats identified by the PM",
      "items": { "type": "string" }
    },

    "summary": {
      "type": "string",
      "description": "Summary of key decisions in the execution plan (1~3 sentences)"
    }
  }
}
