{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntegrationReport",
  "description": "Integration report by skill-integrator. Documents the merge of concern-based implementations.",
  "type": "object",
  "required": ["task_id", "created_at", "concerns_merged", "merge_results", "build_result", "summary"],
  "properties": {

    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]+$"
    },

    "created_at": {
      "type": "string",
      "format": "date-time"
    },

    "concerns_merged": {
      "type": "array",
      "description": "List of concerns that were integrated",
      "items": {
        "type": "object",
        "required": ["approach_id", "concern", "branch"],
        "properties": {
          "approach_id": { "type": "integer" },
          "concern": { "type": "string" },
          "branch": { "type": "string" }
        }
      }
    },

    "merge_results": {
      "type": "array",
      "description": "Per-branch merge status",
      "items": {
        "type": "object",
        "required": ["branch", "status"],
        "properties": {
          "branch": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["clean", "conflict_resolved"]
          },
          "conflicts": {
            "type": "array",
            "description": "Files that had conflicts (if any)",
            "items": {
              "type": "object",
              "properties": {
                "file": { "type": "string" },
                "resolution": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "glue_code": {
      "type": "array",
      "description": "Files added as glue code between concerns",
      "items": {
        "type": "object",
        "required": ["path", "purpose"],
        "properties": {
          "path": { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    },

    "build_result": {
      "type": "object",
      "required": ["success"],
      "properties": {
        "success": { "type": "boolean" },
        "command": { "type": "string" },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "resolution": { "type": "string" }
            }
          }
        }
      }
    },

    "known_issues": {
      "type": "array",
      "description": "Remaining issues after integration",
      "items": { "type": "string" }
    },

    "summary": {
      "type": "string",
      "description": "Brief summary of the integration result"
    }
  }
}
