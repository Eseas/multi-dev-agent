{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review",
  "description": "Goal achievement review results by skill-reviewer. Input for skill-comparator.",
  "type": "object",
  "required": ["task_id", "approach_id", "approach_name", "created_at", "overall_score", "recommendation", "scores", "findings", "summary"],
  "properties": {

    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]+$"
    },

    "approach_id": {
      "type": "integer"
    },

    "approach_name": {
      "type": "string"
    },

    "created_at": {
      "type": "string",
      "format": "date-time"
    },

    "overall_score": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Overall goal achievement score (1-5)"
    },

    "recommendation": {
      "type": "string",
      "enum": ["achieved", "partial", "not_achieved"],
      "description": "Goal achievement verdict"
    },

    "scores": {
      "type": "object",
      "description": "Per-perspective scores",
      "required": ["requirement_fulfillment", "approach_fidelity", "success_criteria", "completeness"],
      "properties": {
        "requirement_fulfillment": { "type": "number", "minimum": 1, "maximum": 5 },
        "approach_fidelity": { "type": "number", "minimum": 1, "maximum": 5 },
        "success_criteria": { "type": "number", "minimum": 1, "maximum": 5 },
        "completeness": { "type": "number", "minimum": 1, "maximum": 5 }
      }
    },

    "requirements_checklist": {
      "type": "array",
      "description": "Checklist of each requirement from the spec",
      "items": {
        "type": "object",
        "required": ["requirement", "fulfilled", "note"],
        "properties": {
          "requirement": { "type": "string", "description": "Requirement from the planning spec" },
          "fulfilled": { "type": "boolean", "description": "Whether this requirement was met" },
          "note": { "type": "string", "description": "Explanation of fulfillment status" }
        }
      }
    },

    "findings": {
      "type": "array",
      "description": "Goal achievement findings",
      "items": {
        "type": "object",
        "required": ["status", "title", "description"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["achieved", "partial", "not_achieved"],
            "description": "Achievement status of this goal/requirement"
          },
          "title": { "type": "string" },
          "requirement": {
            "type": "string",
            "description": "Related requirement from the planning spec"
          },
          "description": { "type": "string" },
          "impact": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },

    "strengths": {
      "type": "array",
      "description": "Goals that were well achieved",
      "items": { "type": "string" }
    },

    "comparison_hints": {
      "type": "object",
      "description": "Hints for the Comparator agent",
      "properties": {
        "excels_at": { "type": "string" },
        "trade_offs": { "type": "string" },
        "best_when": { "type": "string" }
      }
    },

    "summary": {
      "type": "string",
      "description": "2-3 sentence overall goal achievement assessment"
    }
  }
}
