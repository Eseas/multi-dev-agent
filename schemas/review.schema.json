{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review",
  "description": "Code review results by skill-reviewer. Input for skill-comparator.",
  "type": "object",
  "required": ["task_id", "approach_id", "approach_name", "created_at", "overall_score", "recommendation", "scores", "findings", "summary"],
  "properties": {

    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]+$"
    },

    "approach_id": {
      "type": "integer"
    },

    "approach_name": {
      "type": "string"
    },

    "created_at": {
      "type": "string",
      "format": "date-time"
    },

    "overall_score": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Overall score (1-5)"
    },

    "recommendation": {
      "type": "string",
      "enum": ["recommended", "conditional", "not_recommended"],
      "description": "Overall recommendation"
    },

    "scores": {
      "type": "object",
      "description": "Per-perspective scores",
      "required": ["code_quality", "architecture", "security", "performance", "testability"],
      "properties": {
        "code_quality": { "type": "number", "minimum": 1, "maximum": 5 },
        "architecture": { "type": "number", "minimum": 1, "maximum": 5 },
        "security": { "type": "number", "minimum": 1, "maximum": 5 },
        "performance": { "type": "number", "minimum": 1, "maximum": 5 },
        "testability": { "type": "number", "minimum": 1, "maximum": 5 }
      }
    },

    "findings": {
      "type": "array",
      "description": "All review findings",
      "items": {
        "type": "object",
        "required": ["severity", "title", "location", "description", "suggestion"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor"]
          },
          "title": { "type": "string" },
          "location": {
            "type": "string",
            "description": "File path and line number. e.g. src/auth.py:42"
          },
          "description": { "type": "string" },
          "impact": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },

    "strengths": {
      "type": "array",
      "description": "Notable strengths of this implementation",
      "items": { "type": "string" }
    },

    "comparison_hints": {
      "type": "object",
      "description": "Hints for the Comparator agent",
      "properties": {
        "excels_at": { "type": "string" },
        "trade_offs": { "type": "string" },
        "best_when": { "type": "string" }
      }
    },

    "summary": {
      "type": "string",
      "description": "2-3 sentence overall assessment"
    }
  }
}
