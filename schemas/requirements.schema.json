{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Requirements",
  "description": "Requirements document generated by skill-planner. The sole input source for skill-pm.",
  "type": "object",
  "required": ["task_id", "created_at", "user_stories", "scope", "deferred", "conversation_summary"],
  "properties": {

    "task_id": {
      "type": "string",
      "description": "Unique task identifier. e.g. task-001",
      "pattern": "^task-[0-9]+$"
    },

    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "format": "date-time"
    },

    "user_stories": {
      "type": "array",
      "description": "List of user stories. At least 1 required.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "as_a", "i_want", "so_that", "acceptance_criteria", "priority"],
        "properties": {

          "id": {
            "type": "string",
            "description": "User story identifier. e.g. US-001",
            "pattern": "^US-[0-9]+$"
          },

          "as_a": {
            "type": "string",
            "description": "Role. e.g. end user, admin"
          },

          "i_want": {
            "type": "string",
            "description": "Desired feature"
          },

          "so_that": {
            "type": "string",
            "description": "Purpose and value"
          },

          "acceptance_criteria": {
            "type": "array",
            "description": "Acceptance criteria. At least 2, written in testable form.",
            "minItems": 2,
            "items": {
              "type": "string"
            }
          },

          "priority": {
            "type": "string",
            "description": "Priority level",
            "enum": ["must", "should", "could"]
          }
        }
      }
    },

    "scope": {
      "type": "object",
      "description": "Scope definition",
      "required": ["in", "out"],
      "properties": {
        "in": {
          "type": "array",
          "description": "Features included in this task",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "out": {
          "type": "array",
          "description": "Features excluded from this task",
          "items": { "type": "string" }
        }
      }
    },

    "deferred": {
      "type": "array",
      "description": "Deferred items. Must not block core features.",
      "items": { "type": "string" }
    },

    "conversation_summary": {
      "type": "string",
      "description": "Summary of key decisions from the planner-user conversation"
    },

    "pipeline_hint": {
      "type": "object",
      "description": "Pipeline hints for the PM (optional)",
      "properties": {
        "complexity": {
          "type": "string",
          "enum": ["simple", "medium", "complex"],
          "description": "simple: Architect can be skipped / complex: full pipeline recommended"
        },
        "requires_design": {
          "type": "boolean",
          "description": "Whether a design phase is needed"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
